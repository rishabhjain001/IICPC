# ============================================================
# DBHP — Distributed Benchmarking and Hosting Platform
# .env.example
#
# Copy this file to .env and fill in values for your environment:
#   cp .env.example .env
#
# NEVER commit a .env file containing real secrets.
# All values shown here are safe defaults for local development only.
# ============================================================

# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure — PostgreSQL / TimescaleDB
# ─────────────────────────────────────────────────────────────────────────────

# Full PostgreSQL DSN used by all services that talk to TimescaleDB.
DATABASE_URL=postgresql://dbhp:dbhp@timescaledb:5432/dbhp

# Used by the timescaledb container itself.
POSTGRES_USER=dbhp
POSTGRES_PASSWORD=dbhp
POSTGRES_DB=dbhp

# Host port to expose TimescaleDB on (change if 5432 is already taken locally).
TIMESCALEDB_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure — Redis
# ─────────────────────────────────────────────────────────────────────────────

# Redis connection address used by platform services.
REDIS_ADDR=redis:6379

# Full Redis URL used by the Submission Engine (redis:// scheme).
REDIS_URL=redis://redis:6379

# Host port to expose Redis on.
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure — Kafka / Redpanda
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of Kafka bootstrap broker addresses (internal network).
KAFKA_BROKERS=redpanda:9092

# Consumer group ID for the Telemetry Ingester.
KAFKA_GROUP_ID=telemetry-ingester

# Environment suffix appended to topic names (dev | staging | prod).
KAFKA_ENV=dev

# Host ports to expose Redpanda on.
REDPANDA_KAFKA_PORT=9092
REDPANDA_ADMIN_PORT=9644

# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure — Artifact Registry (Docker Registry v2)
# ─────────────────────────────────────────────────────────────────────────────

# Internal URL used by platform services to push / pull OCI images.
ARTIFACT_REGISTRY_URL=http://registry:5000

# Host port to expose the registry on.
REGISTRY_PORT=5000

# ─────────────────────────────────────────────────────────────────────────────
# Security — shared secrets
# ─────────────────────────────────────────────────────────────────────────────

# Bearer token used for internal service-to-service gRPC authentication.
# CHANGE THIS to a strong random value in any non-local environment.
INTERNAL_BEARER_TOKEN=dev-secret-token

# ─────────────────────────────────────────────────────────────────────────────
# Submission Engine
# ─────────────────────────────────────────────────────────────────────────────

# Path to the TLS certificate and private key inside the container.
# Mount real certs via a volume or Kubernetes secret in production.
TLS_CERT_FILE=/certs/server.crt
TLS_KEY_FILE=/certs/server.key

# ─────────────────────────────────────────────────────────────────────────────
# Build Pipeline
# ─────────────────────────────────────────────────────────────────────────────

# Kubernetes namespace where build Jobs are spawned.
BUILD_NAMESPACE=dbhp-builds

# Path to kubeconfig (leave empty to use in-cluster service account).
KUBECONFIG=

# ─────────────────────────────────────────────────────────────────────────────
# Sandbox Controller
# ─────────────────────────────────────────────────────────────────────────────

# Kubernetes namespace managed by the Sandbox Controller operator.
CONTROLLER_NAMESPACE=dbhp-sandboxes

# ─────────────────────────────────────────────────────────────────────────────
# Bot Fleet Manager
# ─────────────────────────────────────────────────────────────────────────────

# Kubernetes node label selector used to find eligible bot-worker nodes.
BOT_WORKER_LABEL=role=bot-worker

# Heartbeat interval in seconds between bot-agent and BFM.
HEARTBEAT_INTERVAL_S=5

# Seconds without a heartbeat before a node is considered failed.
NODE_FAILURE_TIMEOUT_S=15

# ─────────────────────────────────────────────────────────────────────────────
# Telemetry Ingester
# ─────────────────────────────────────────────────────────────────────────────

# Full PostgreSQL DSN for TimescaleDB (may differ from DATABASE_URL if using
# a dedicated read/write endpoint).
TIMESCALE_DSN=postgresql://dbhp:dbhp@timescaledb:5432/dbhp

# Path inside the container where the compiled RME shared library is found.
# The docker-compose.yml mounts ./libs/rme into /rme; after `cargo build
# --release` the .so lands at /rme/target/release/libdbhp_rme.so.
RME_LIB_PATH=/rme/target/release/libdbhp_rme.so

# ─────────────────────────────────────────────────────────────────────────────
# Leaderboard Service
# ─────────────────────────────────────────────────────────────────────────────

# (No additional variables beyond the shared ones above.)

# ─────────────────────────────────────────────────────────────────────────────
# Leaderboard Frontend
# ─────────────────────────────────────────────────────────────────────────────

# WebSocket URL the browser connects to (replace with public hostname in prod).
LEADERBOARD_WS_URL=ws://leaderboard-service:8082/v1/ws/leaderboard

# REST base URL used for the initial leaderboard snapshot fetch.
LEADERBOARD_API_URL=http://leaderboard-service:8082

# ─────────────────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────────────────

# Minimum log level emitted by all Go services (debug|info|warn|error).
LOG_LEVEL=info

# OpenTelemetry OTLP endpoint (leave empty to disable tracing locally).
OTEL_EXPORTER_OTLP_ENDPOINT=

# Prometheus scrape target for the Control Plane API metrics endpoint.
# Control Plane gRPC listens on :9090; metrics on :9091.
